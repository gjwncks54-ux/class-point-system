rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "JVgbee2GguPVKad6oGsorTeH7fY2";
    }

    function validPurchaseRequest() {
      return request.resource.data.keys().hasOnly([
        'type', 'cid', 'sid', 'studentName', 'className',
        'item', 'price', 'date', 'createdAtMs', 'isPublic'
      ]) &&
      request.resource.data.type == 'purchase' &&
      request.resource.data.price is int &&
      request.resource.data.price >= 0;
    }

    function validPinRequest() {
      return request.resource.data.keys().hasOnly([
        'type', 'cid', 'sid', 'studentName', 'className',
        'newPin', 'date', 'createdAtMs'
      ]) &&
      request.resource.data.type == 'pinChange' &&
      request.resource.data.newPin is string &&
      request.resource.data.newPin.size() == 4;
    }

    match /app/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if validPurchaseRequest() || validPinRequest();
      allow read, update, delete: if isAdmin();
    }

    match /gameSessions/{sessionId} {
      allow read, write: if false;
    }

    match /gameLogs/{logId} {
      allow read, write: if false;
    }

    match /gachaLogs/{logId} {
      allow read, write: if false;
    }

    match /ticker/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /villageStatus/{classId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dennisVillageWeeks/{weekId}/classes/{classId}/students/{studentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
